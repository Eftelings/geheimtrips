# ── Geheimtrips API — Umgebungsvariablen ─────────────────────────────────────
# Diese Datei kopieren nach .env (lokal) bzw. in Railway als Variablen eintragen.

# Pflicht in Produktion: eigenes, langes Zufalls-Secret für JWT-Signierung.
# Ohne dieses sind alle Login-Tokens fälschbar! (z.B. `openssl rand -hex 32`)
JWT_SECRET=

# Datenbank — Turso/libsql. Lokal leer lassen → SQLite-Datei wird genutzt.
# DATABASE_URL=libsql://dein-projekt.turso.io
# DATABASE_AUTH_TOKEN=eyJ...

# Persistentes Upload-Verzeichnis (Railway-Volume), z.B. /data/uploads.
# Lokal leer lassen → ./uploads.
# UPLOAD_DIR=/data/uploads

# Frontend wird vom selben Server ausgeliefert → Pfad zum gebauten web/dist.
# Im Docker-Image bereits auf "public" gesetzt; lokal leer lassen (Vite separat).
# STATIC_DIR=public

# Nur nötig, wenn Frontend auf einer ANDEREN Domain läuft (getrenntes Hosting):
# CORS_ORIGINS=https://geheimtrips.de,https://www.geheimtrips.de

# Port (Railway setzt das automatisch; lokal Fallback 3001)
# PORT=3001

# ── E-Mail-Versand (Bestätigungs-, Reset-, Newsletter-Mails) ─────────────────
# Ohne eines der beiden Verfahren werden Mails NUR ins Log geschrieben — und neue
# Nutzer werden dann automatisch als bestätigt angelegt (niemand wird ausgesperrt).
#
# Empfohlen (funktioniert auf Railway, wo SMTP-Ports geblockt sind): Resend HTTP-API.
#   1) Konto auf resend.com, Domain geheimtrips.de verifizieren (DNS-Records setzen)
#   2) API-Key erstellen und hier eintragen:
# RESEND_API_KEY=re_...
#
# Alternative: klassisches SMTP (lokal / Hoster ohne SMTP-Sperre).
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587            # 465 = implizites TLS, 587 = STARTTLS
# SMTP_USER=postmaster@geheimtrips.de
# SMTP_PASS=...
#
# Absender-Adresse (muss zur verifizierten Domain passen):
# SMTP_FROM=Geheimtrips.de <info@geheimtrips.de>
#
# Basis-URL für Links in den Mails (Bestätigung/Reset). Default: https://www.geheimtrips.de
# APP_URL=https://www.geheimtrips.de

# ── Bot-Schutz: Cloudflare Turnstile ────────────────────────────────────────
# Ohne dieses Secret wird NICHT geprüft (lokal bequem, in Produktion ungeschützt).
# Ist es gesetzt, brauchen Registrierung und Passwort-Reset einen gültigen Token.
# Das öffentliche Gegenstück (Sitekey) steht in web/.env.production.
TURNSTILE_SECRET=

# ── Anmelden mit Google ─────────────────────────────────────────────────────
# Nur noetig, wenn eine ANDERE als die im Code hinterlegte Client-ID gelten soll
# (z.B. eigenes Google-Projekt). Sie ist oeffentlich, ein Secret braucht es nicht.
# GOOGLE_CLIENT_ID=...apps.googleusercontent.com
