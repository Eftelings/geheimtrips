# ── Geheimtrips API — Umgebungsvariablen ─────────────────────────────────────
# Diese Datei kopieren nach .env (lokal) bzw. in Railway als Variablen eintragen.

# Pflicht in Produktion: eigenes, langes Zufalls-Secret für JWT-Signierung.
# Ohne dieses sind alle Login-Tokens fälschbar! (z.B. `openssl rand -hex 32`)
JWT_SECRET=

# Datenbank — Turso/libsql. Lokal leer lassen → SQLite-Datei wird genutzt.
# DATABASE_URL=libsql://dein-projekt.turso.io
# DATABASE_AUTH_TOKEN=eyJ...

# Persistentes Upload-Verzeichnis (Railway-Volume), z.B. /data/uploads.
# Lokal leer lassen → ./uploads.
# UPLOAD_DIR=/data/uploads

# Frontend wird vom selben Server ausgeliefert → Pfad zum gebauten web/dist.
# Im Docker-Image bereits auf "public" gesetzt; lokal leer lassen (Vite separat).
# STATIC_DIR=public

# Nur nötig, wenn Frontend auf einer ANDEREN Domain läuft (getrenntes Hosting):
# CORS_ORIGINS=https://geheimtrips.de,https://www.geheimtrips.de

# Port (Railway setzt das automatisch; lokal Fallback 3001)
# PORT=3001
