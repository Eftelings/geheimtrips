# Cloudflare Turnstile — der Sitekey ist öffentlich: er steht in jedem ausgelieferten
# HTML und identifiziert nur das Widget. Deshalb liegt er im Repository, damit jeder
# Produktions-Build ihn hat. Das Gegenstück (TURNSTILE_SECRET) gehört NUR in die
# Server-Umgebung und niemals hierher.
VITE_TURNSTILE_SITE_KEY=0x4AAAAAAD6xlhKgf3ILKq-H

# Google-Anmeldung. Die Client-ID ist oeffentlich (sie steht im ausgelieferten HTML)
# und identifiziert nur die App. Ein Client Secret braucht dieser Weg nicht.
VITE_GOOGLE_CLIENT_ID=581781823367-7sr1ldvvacifaffdmhfip6i5os3iq36m.apps.googleusercontent.com
